-static int eip93_hash_cra_init(struct crypto_tfm *tfm)
-{
-	struct eip93_hash_ctx *ctx = crypto_tfm_ctx(tfm);
-	struct eip93_alg_template *tmpl = container_of(tfm->__crt_alg,
-				struct eip93_alg_template, alg.ahash.halg.base);
