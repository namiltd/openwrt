
. /lib/functions.sh
. /lib/functions/uci-defaults.sh

board_config_update

case "$(board_name)" in
	elecom,wrc-2533gent|\
	totolink,a8000ru)
		ucidef_set_compat_version "1.1"
		;;
	bananapi,bpi-r64|\
	buffalo,wsr-2533dhp2)
		ucidef_set_compat_version "1.2"
		;;
	linksys,e8450-ubi)
		ucidef_set_compat_version "2.0"
		;;
esac

board_config_flush

exit 0
